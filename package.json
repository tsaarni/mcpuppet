{
  "name": "mcpuppet",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "mcpuppet-cli": "./dist/src/cli.js"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env.example src/main.ts",
    "build": "tsc",
    "postbuild": "chmod +x dist/src/cli.js",
    "start": "node dist/src/main.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@modelcontextprotocol/sdk": "^1.17.4",
    "@mozilla/readability": "^0.6.0",
    "async-mutex": "^0.5.0",
    "consola": "^3.4.2",
    "hono": "^4.6.12",
    "linkedom": "^0.18.12",
    "puppeteer": "^24.15.0",
    "turndown": "^7.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/mozilla__readability": "^0.4.2",
    "@types/node": "^24.3.0",
    "@types/turndown": "^5.0.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
